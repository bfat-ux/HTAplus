# Copy this file to /etc/hta-ddns.env on the Pi, fill in the key/secret,
# and chmod 600 /etc/hta-ddns.env so only root can read it.

# --- Required -----------------------------------------------------------------

# Production API key + secret from https://developer.godaddy.com/keys
# IMPORTANT: you want "Production" keys, not "OTE" (test environment).
GODADDY_KEY=REPLACE_ME
GODADDY_SECRET=REPLACE_ME

# --- Optional (shown with their defaults) -------------------------------------

# Base domain you manage in GoDaddy
DOMAIN=htaplus.com

# Subdomain label to keep pointed at your current public IP
RECORD_NAME=api

# TTL in seconds. 600 (10 min) is a reasonable balance: long enough for DNS
# caches to behave, short enough that an IP change recovers quickly.
TTL=600

# Optional overrides (usually leave alone)
# IP_CHECK_URL=https://api.ipify.org
# STATE_FILE=/var/lib/hta-ddns/last-ip
